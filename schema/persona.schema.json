{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/5dive-ai/openagent/main/schema/persona.schema.json",
  "title": "OpenAgent Persona",
  "type": "object",
  "required": ["id", "name", "role", "face", "voice", "behavior"],
  "additionalProperties": false,
  "properties": {
    "openagent": { "type": "string", "description": "spec version, e.g. \"0.1\"" },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "role": { "type": "string" },
    "behavior": { "type": "string" },
    "posts_about": { "type": "array", "items": { "type": "string" } },
    "face": {
      "type": "object",
      "required": ["ref", "anchor"],
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string" },
        "anchor": { "type": "string" },
        "full": { "type": "string" },
        "sprite": { "type": "string" },
        "recipe": {
          "type": "object",
          "description": "optional regeneration recipe — makes the canonical likeness reproducible (model + prompt + seed) the same way voice is from base + style, instead of a single frozen PNG.",
          "required": ["model", "prompt"],
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string", "description": "the named image model that produced ref (e.g. \"imagen-4\", \"flux-1.1-pro\")." },
            "prompt": { "type": "string", "description": "the generation prompt that yields the canonical likeness." },
            "seed": { "type": ["integer", "string"], "description": "the seed used; pin it for deterministic re-gens (omit if the model exposes none)." }
          }
        }
      }
    },
    "voice": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "audio": {
          "type": "object",
          "required": ["base"],
          "additionalProperties": false,
          "properties": {
            "base": { "type": "string" },
            "style": { "type": "string" },
            "ref": { "type": "string" },
            "id": { "type": "string" }
          }
        },
        "written": {
          "type": "object",
          "required": ["rules", "sample"],
          "additionalProperties": false,
          "properties": {
            "rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "sample": { "type": "string" }
          }
        }
      }
    },
    "links": { "type": "object", "additionalProperties": { "type": "string" } }
  }
}
